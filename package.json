{
  "name": "@kf/workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @kf/studio dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "check": "pnpm lint && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @kf/db db:generate",
    "db:migrate": "pnpm --filter @kf/db db:migrate",
    "db:studio": "pnpm --filter @kf/db db:studio",
    "infra:up": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/docker-compose.ps1 up postgres",
    "infra:down": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/docker-compose.ps1 down",
    "infra:logs": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -ExecutionPolicy Bypass -File scripts/docker-compose.ps1 logs -f postgres",
    "graph:update": "powershell -ExecutionPolicy Bypass -File scripts/graphify.ps1 update ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
