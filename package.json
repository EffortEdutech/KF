{
  "name": "@kf/workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "pnpm --filter @kf/studio dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "check": "pnpm lint && pnpm test && pnpm build",
    "db:generate": "pnpm --filter @kf/db db:generate",
    "db:migrate": "pnpm --filter @kf/db db:migrate",
    "db:studio": "pnpm --filter @kf/db db:studio",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres",
    "graph:update": "powershell -ExecutionPolicy Bypass -File scripts/graphify.ps1 update ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
