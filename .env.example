# Knowledge Factory local development environment
# Copy to .env and change local-only values if needed.

NODE_ENV=development

# Dedicated KF PostgreSQL container.
# Do not reuse databases or containers from other projects.
KF_POSTGRES_USER=kf_app
KF_POSTGRES_PASSWORD=kf_dev_password
KF_POSTGRES_DB=kf_dev
KF_POSTGRES_PORT=55432
DATABASE_URL=postgresql://kf_app:kf_dev_password@localhost:55432/kf_dev?schema=public

# Local file storage used by the initial StorageProvider.
KF_STORAGE_ROOT=./storage

# AI model-router defaults.
KF_AI_PROVIDER=fake
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Local single-user bootstrap identity.
KF_LOCAL_ORG_ID=local-org
KF_LOCAL_WORKSPACE_ID=local-workspace
KF_LOCAL_USER_EMAIL=admin@kf.local
